# halfscarf — Spike A (WDK payment) configuration.
# Copy to `.env` and fill in. NEVER commit a real seed phrase or private key.

# BIP-39 seed phrase of the SENDER wallet. Leave blank to auto-generate a fresh
# (unfunded) wallet for a read-only diagnostic run.
WDK_SEED=

# EVM testnet RPC endpoint. Default is a public Sepolia RPC (no API key needed).
SEPOLIA_RPC_URL=https://sepolia.drpc.org

# ERC-20 token contract used as the "USDt" for balance reads + transfers on the
# testnet. On a live public testnet this is a USDt stand-in ERC-20 (see RISKS.md).
USDT_ADDRESS=
USDT_DECIMALS=6

# --- Transfer step (optional) ---
# Set all three to actually send a transfer. Requires the sender wallet to hold
# testnet gas (native ETH) AND some of the token above.
RECIPIENT=
TRANSFER_AMOUNT=
